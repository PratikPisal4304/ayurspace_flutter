flowchart LR
    classDef process fill:#fff,stroke:#000,stroke-width:2px,color:#000
    classDef entity fill:#fff,stroke:#000,stroke-width:2px,color:#000
    classDef store fill:#fff,stroke:#000,stroke-width:1px,color:#000

    subgraph Col0[" "]
        direction TB
        User["User"]:::entity
    end

    subgraph Col1[" "]
        direction TB
        P1(("1.1<br/>Authentication")):::process
        Firebase["Firebase"]:::entity
        D1["D1 | User Database"]:::store
        P1 -->|"Auth Data"| D1
        Firebase -->|"Auth Access"| D1
    end

    subgraph Col2[" "]
        direction TB
        P2(("1.2<br/>Browse<br/>Content")):::process
        D2["D2 | Plant & Remedy Data"]:::store
        D2 -->|"Records"| P2
    end

    subgraph Col3[" "]
        direction TB
        P3(("1.3<br/>Plant<br/>Scanner")):::process
    end

    subgraph Col4[" "]
        direction TB
        P4(("1.4<br/>AI Chat")):::process
        D4["D4 | Preferences"]:::store
        P4 -->|"Session Data"| D4
    end

    subgraph Col5[" "]
        direction TB
        P5(("1.5<br/>Wellness<br/>& Profile")):::process
        D3["D3 | Quiz Data"]:::store
        D3 -->|"Questions"| P5
    end

    style Col0 fill:none,stroke:none
    style Col1 fill:none,stroke:none
    style Col2 fill:none,stroke:none
    style Col3 fill:none,stroke:none
    style Col4 fill:none,stroke:none
    style Col5 fill:none,stroke:none

    User -->|"Credentials"| P1
    P1 -->|"Auth Token"| P2
    P2 -->|"Plant Data"| P3
    P3 -->|"Scan Result"| P4
    P4 -->|"Chat Context"| P5
    P5 -->|"User Profile"| User

    D2 -->|"Local Match"| P3
    D4 -->|"Saved Stats"| P5
    P5 -->|"Wellness Data"| D4
