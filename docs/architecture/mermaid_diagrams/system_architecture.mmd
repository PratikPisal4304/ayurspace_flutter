    USER(["User · Device Camera · ImagePicker"])

    PRESENT["Presentation Layer<br/>17 Screens · GoRouter · 6 Auth Guards<br/>ShellRoute — 6 Tab Bottom Navigation<br/>Localization EN · HI · MR via gen_l10n<br/>Material 3 · AppTheme · AppColors · DesignTokens"]:::client

